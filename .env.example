# 🌍 Trip Planner — Environment Configuration Example

# ── Google / Gemini ──────────────────────────────────────────────────────
# Required: API key for Gemini 2.5 Flash and Google Search
GOOGLE_API_KEY=your_google_api_key_here

# Optional: Use Vertex AI instead of Google AI Studio
# GOOGLE_GENAI_USE_VERTEXAI=false

# ── Security ─────────────────────────────────────────────────────────────
# Required in production: 32-byte hex string for JWT signing.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# Optional security settings
# ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Rate Limiting ────────────────────────────────────────────────────────
# RATE_LIMIT_REQUESTS=10
# RATE_LIMIT_WINDOW_SECONDS=60

# ── Input / Output Filters ───────────────────────────────────────────────
# MAX_INPUT_LENGTH=1000
# MAX_OUTPUT_LENGTH=50000

# ── Logging ──────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO
# LOG_FILE=logs/audit.jsonl

# ── API Configuration ────────────────────────────────────────────────────
# API_HOST=0.0.0.0
# API_PORT=8000

# ── Authentication ───────────────────────────────────────────────────────
# ADMIN_USERNAME=admin

# Required: bcrypt hash of the admin password.
# Generate with: uv run scripts/hash_creator.py
ADMIN_PASSWORD_HASH=your_bcrypt_hash_here
